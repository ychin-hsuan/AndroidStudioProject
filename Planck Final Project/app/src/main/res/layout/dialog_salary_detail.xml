<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/dialog_background">

        <!-- 標題 -->
        <TextView
            android:id="@+id/tv_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carrefour 薪資明細"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_detail_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026年 5月"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp"/>

        <!-- 分隔線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/planck_purple_light"
            android:layout_marginBottom="14dp"/>

        <!-- 班次統計 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="本月班數"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_detail_shifts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6 班"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- 時數 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="本月時數"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_detail_hours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="38.3 hr"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- 時薪 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="時薪"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_detail_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$196"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- 總薪資 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="總薪資"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_detail_gross"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$7,505"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- 分隔線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/planck_purple_light"
            android:layout_marginBottom="14dp"/>

        <!-- 勞保自付 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="勞保自付"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_labor"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/input_background"
                    android:padding="8dp"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 健保自付 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="健保自付"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"/>
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_health"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="0"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/input_background"
                    android:padding="8dp"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/planck_purple_light"
            android:layout_marginBottom="14dp"/>

        <!-- 實領薪資 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="實領薪資"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:id="@+id/tv_detail_net"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$7,505"
                android:textSize="18sp"
                android:textColor="@color/planck_purple"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- 按鈕 -->
        <Button
            android:id="@+id/btn_close"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="關閉"
            android:backgroundTint="@color/planck_purple"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</ScrollView>