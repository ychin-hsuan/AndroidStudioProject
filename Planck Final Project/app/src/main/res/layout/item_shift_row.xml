<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <View
        android:id="@+id/view_shift_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_dot"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_shift_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4月24日 週四"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tv_shift_scheduled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="預計 14:00–22:00 · 8hr"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_shift_actual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="尚未打卡"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_shift_pay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tv_shift_diff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待確認"
            android:textSize="10sp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/badge_green"
            android:textColor="@color/planck_green"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>