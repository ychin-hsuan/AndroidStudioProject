<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- 勾選圓圈 -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkbox_todo"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        app:buttonTint="@color/planck_purple"/>

    <!-- 文字區塊 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_todo_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="待辦名稱"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tv_todo_deadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="截止：今日 23:59"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_postpone_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="延後到明天"
            android:textSize="10sp"
            android:textColor="@color/planck_purple"
            android:layout_marginTop="3dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- 優先度 badge -->
    <TextView
        android:id="@+id/tv_todo_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="緊急"
        android:textSize="10sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:background="@drawable/badge_red"
        android:textColor="@color/planck_red"/>

</LinearLayout>