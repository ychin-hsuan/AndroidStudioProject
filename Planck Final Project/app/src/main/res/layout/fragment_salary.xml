<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- 頂部月份導覽 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_prev_month"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="‹"
            android:textSize="22sp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:background="@drawable/badge_green"/>

        <TextView
            android:id="@+id/tv_month_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2025年 4月"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"/>

        <TextView
            android:id="@+id/btn_next_month"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="›"
            android:textSize="22sp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:background="@drawable/badge_green"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- 主要薪資卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/planck_purple">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本月實際薪資"
                        android:textSize="11sp"
                        android:textColor="#B0AADE"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tv_actual_pay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="32sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="實際時數"
                                android:textSize="10sp"
                                android:textColor="#B0AADE"/>
                            <TextView
                                android:id="@+id/tv_actual_hours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 hr"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="預計薪資"
                                android:textSize="10sp"
                                android:textColor="#B0AADE"/>
                            <TextView
                                android:id="@+id/tv_scheduled_pay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="14sp"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="差額"
                                android:textSize="10sp"
                                android:textColor="#B0AADE"/>
                            <TextView
                                android:id="@+id/tv_diff_pay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="14sp"
                                android:textColor="#FAC775"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 統計小卡 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">


                <!-- 工作時數卡片區 -->
                <LinearLayout
                    android:id="@+id/layout_job_hours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:id="@+id/layout_job_hours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="2dp"/>


            </LinearLayout>

            <!-- 近期班表標題 + 新增按鈕 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="近期班表"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"/>

                <TextView
                    android:id="@+id/btn_add_shift"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ 新增班次"
                    android:textSize="12sp"
                    android:textColor="@color/planck_purple"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <!-- 班表列表 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:id="@+id/layout_shifts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- 右下角 FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_job"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="新增工作"
        app:backgroundTint="@color/planck_purple"
        app:tint="@color/white"/>

</LinearLayout>