<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/dialog_background">

        <!-- 標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新增事件"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="20dp"/>

        <!-- 事件名稱 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="事件名稱"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 類型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="類型"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <RadioGroup
            android:id="@+id/rg_event_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <RadioButton
                android:id="@+id/rb_type_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="需要時間"
                android:textSize="13sp"
                android:buttonTint="@color/planck_purple"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_type_remind"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="只需提醒"
                android:textSize="13sp"
                android:buttonTint="@color/planck_purple"/>

        </RadioGroup>

        <!-- 優先度 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="優先度"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <RadioGroup
            android:id="@+id/rg_priority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_priority_normal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="一般"
                android:textSize="13sp"
                android:buttonTint="@color/planck_green"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_priority_important"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="重要"
                android:textSize="13sp"
                android:buttonTint="@color/planck_orange"/>

            <RadioButton
                android:id="@+id/rb_priority_urgent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="緊急"
                android:textSize="13sp"
                android:buttonTint="@color/planck_red"/>

        </RadioGroup>

        <!-- 分隔線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/planck_purple_light"
            android:layout_marginBottom="16dp"/>

        <!-- 時間區塊：開始 → 結束 並排 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <!-- 開始時間 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="開始"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_start_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="選擇日期"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:padding="10dp"
                    android:background="@drawable/input_background"
                    android:layout_marginBottom="6dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tv_start_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="09:00"
                    android:textSize="18sp"
                    android:textColor="@color/planck_purple"
                    android:fontFamily="sans-serif-medium"
                    android:padding="10dp"
                    android:background="@drawable/input_background"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- 箭頭 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="20sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="20dp"/>

            <!-- 結束時間 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="結束"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_end_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="選擇日期"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:padding="10dp"
                    android:background="@drawable/input_background"
                    android:layout_marginBottom="6dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/tv_end_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:textSize="18sp"
                    android:textColor="@color/planck_purple"
                    android:fontFamily="sans-serif-medium"
                    android:padding="10dp"
                    android:background="@drawable/input_background"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/planck_purple_light"
            android:layout_marginBottom="16dp"/>

        <!-- 推薦可安排時段 -->
        <TextView
            android:id="@+id/tv_slot_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="推薦可安排時段"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"
            android:visibility="gone"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_slots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface"
            android:visibility="gone"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:id="@+id/layout_slots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp"/>

        </androidx.cardview.widget.CardView>

        <!-- 備註 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="備註（選填）"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_event_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 按鈕列 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textColor="@color/text_secondary"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新增"
                android:backgroundTint="@color/planck_purple"
                style="@style/Widget.MaterialComponents.Button"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>