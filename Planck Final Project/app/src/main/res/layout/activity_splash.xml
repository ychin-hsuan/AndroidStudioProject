<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/planck_purple"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- App Icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_icon"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#3C3489"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_schedule"
            android:tint="@color/white"
            android:padding="20dp"/>

    </androidx.cardview.widget.CardView>

    <!-- App 名稱 -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Planck"
        android:textSize="36sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tv_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="精準掌握你的每一天"
        android:textSize="13sp"
        android:textColor="#B0AADE"
        android:layout_marginBottom="40dp"/>

    <!-- 貓咪跑步區域 -->
    <FrameLayout
        android:id="@+id/cat_stage"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp">

        <!-- 地面線 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#6B63CC"
            android:layout_gravity="bottom"
            android:layout_marginBottom="8dp"/>

        <!-- 貓咪 -->
        <ImageView
            android:id="@+id/iv_cat"
            android:layout_width="68dp"
            android:layout_height="56dp"
            android:src="@drawable/cat_animation"
            android:layout_gravity="bottom"
            android:layout_marginBottom="9dp"/>

    </FrameLayout>

    <!-- 載入文字 -->
    <TextView
        android:id="@+id/tv_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="載入中..."
        android:textSize="11sp"
        android:textColor="#8080C0"
        android:letterSpacing="0.05"/>

</LinearLayout>